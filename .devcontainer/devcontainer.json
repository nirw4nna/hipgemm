{
  "name": "ROCm PyTorch",
  "image": "rocm/pytorch:rocm7.2.2_ubuntu24.04_py3.12_pytorch_release_2.10.0",

  "remoteEnv": {
    "PATH": "/root/.local/bin:${containerEnv:PATH}"
  },

  "runArgs": [
    "--device=/dev/kfd",
    "--device=/dev/dri",
    "--group-add=video"
  ],

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "DavidAnson.vscode-markdownlint",
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "xaver.clang-format",
        "llvm-vs-code-extensions.vscode-clangd"
      ]
    }
  }
}